# GigaEvo .gitignore
# Grouped by concern. If you add a rule, put it in the matching section.
# Re-includes (!pattern) override broader rules above them.

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
*.manifest
*.spec
.installed.cfg
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
share/python-wheels/
var/
wheels/
MANIFEST

# Environments / dep managers
.env
.env.*
!.env.example
.venv
venv/
env/
ENV/
env.bak/
venv.bak/
__pypackages__/
.pdm.toml

# Test / coverage / type-check caches
.cache
.coverage
.coverage.*
.dmypy.json
dmypy.json
.hypothesis/
.mypy_cache/
.nox/
.pyre/
.pytest_cache/
.pytype/
.ruff_cache/
.tox/
cover/
coverage.xml
htmlcov/
nosetests.xml
*.cover
*.py,cover

# Profiling
*.prof
*.profile

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb
!tools/**/*.ipynb
ipython_config.py
profile_default/

# ---------------------------------------------------------------------------
# Node / frontend (for tools/dag_builder)
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
*.tsbuildinfo
.npm
.eslintcache
.stylelintcache
.parcel-cache
.next/
.nuxt/
storybook-static/
*.tgz

# ---------------------------------------------------------------------------
# Editors / OS
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Logs, pids, backups, temp
# ---------------------------------------------------------------------------
*.log
logs/
*.pid
*.pid.lock
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*.save
*.dump
*.hprof
*.zip
*.tar.gz
*.tar.bz2
*.rar
scratch/
temp/
tmp/

# ---------------------------------------------------------------------------
# Data & model binaries
# ---------------------------------------------------------------------------
*.csv
*.json
*.jsonl
*.pickle
*.pkl
*.h5
*.hdf5
*.parquet
*.npz
*.rdb
*.model
*.pth
*.pt
*.ckpt
*.weights
*.bin
*.safetensors
*.db
*.sqlite
*.sqlite3

# Keep these config JSON files in-repo
!pyrightconfig.json

# Keep benchmark history (small, append-only) — rebuild with scripts if lost
!tools/benchmark_history.jsonl

# ---------------------------------------------------------------------------
# Generated visual artifacts
# ---------------------------------------------------------------------------
*.png
*.pdf
*.jpg
*.jpeg
*.svg

# Keep UI/demo SVGs checked in
!demos/**/*.svg

# ---------------------------------------------------------------------------
# GigaEvo experiment runtime artifacts
# ---------------------------------------------------------------------------
experiments/**/plots/
experiments/**/test_evals/
experiments/**/archives/
experiments/**/*.yaml.tmp
experiments/**/*.yaml.lock
experiments/**/pids.txt
experiments/**/cfg_run_*.txt
experiments/*/paper_draft.md
experiments/*/paper_review.md
experiments/*/paper_data.json

# Evolution outputs scattered at root / top-level
*results*
*top_programs

# Keep 05_results.md despite the broad *results* rule above
!experiments/**/05_results.md
results_*/
outputs/
run_*/
experiment_*/
evolution_experiment_*/
program_archive/
archive_*/
archives/
evolution_data*
fitness_*.csv
fitness_*.json
fitness_*.txt
behavior_*.csv
behavior_*.json
migration_*.csv
migration_*.json

# Data roots (binary artifacts)
data/
outcmaes/
plots/
snapshots/
benchmark

# Loop / Hydra run outputs (top-level)
output/
runs/

# Rotated / sampler logs not covered by *.log (already above)
tools/.litellm_sampler.log*

# Throwaway exploration tooling
tools/benchmark_gemini_ab/
tools/insights_ablation/
tools/lineage_card_scaffold/

# ---------------------------------------------------------------------------
# LLM / memory stores (local caches, not for VCS)
# ---------------------------------------------------------------------------
.llm_cache/
llm_cache/
models/
evo_memory_agent/
gigaevo.memory/
gigaevo/memory/memory_usage_store/
insights_appearence/
selected_ideas/
redis_commands.txt
mut_dmp/
token_usage_*.log
api_calls_*.log

# Dataset indexes (rebuild locally)
bm25s_index/
task_bm25s_index
problems/chains/hotpotqa/dataset/bm25s_index/
problems/chains/hotpotqa/dataset/colbert_index/
problems/chains/hover/dataset/bm25s_index/
problems/chains/hover/dataset/*.gz
problems/chains/hover/dataset/*.pkl
problems/chains/hover/dataset/*.tar.bz2
problems/chains/hover/dataset/*.jsonl
wiki17_abstracts.jsonl.gz

# ---------------------------------------------------------------------------
# Tooling: litellm proxy (generated config/DB/logs/pidfile)
# ---------------------------------------------------------------------------
tools/.litellm_config.yaml
tools/.litellm.db
tools/.litellm.log
tools/.litellm.pid

# ---------------------------------------------------------------------------
# Claude Code & agent tooling (machine-specific)
# ---------------------------------------------------------------------------
.claude/projects/
.claude/agent-memory/
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/perf-sprint-*.md
.claude/hookify.*.local.md
AGENTS.md
.codex
.worktrees/
.gitnexus/
docs/superpowers/
graphify-out/
site/

# ---------------------------------------------------------------------------
# Repo-local scratch files
# ---------------------------------------------------------------------------
check_openrouter_key.py
experiments.txt
AlgoTune-main/
gigaevo/llm/ideas_tracker/utils/it_logger_description.md

# ---------------------------------------------------------------------------
# Secrets / keys (belt and suspenders; .env is already ignored above)
# ---------------------------------------------------------------------------
secrets.json
id_rsa
id_rsa.pub
*.pem
